# ── SMTP (Gmail App Password recommended) ──
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_TO=courtney@rivercapital.com.au
EMAIL_FROM=your-email@gmail.com

# ── Paywall Logins ──
AFR_EMAIL=your-afr-login@email.com
AFR_PASSWORD=your-afr-password
AUSTRALIAN_EMAIL=your-australian-login@email.com
AUSTRALIAN_PASSWORD=your-australian-password

# ── Anthropic API ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Excel output path (default: news_log.xlsx in repo root) ──
EXCEL_PATH=news_log.xlsx
